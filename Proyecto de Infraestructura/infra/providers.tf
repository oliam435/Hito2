terraform {
  required_version = ">= 1.5.0"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = "~> 2.4"
    }
  }
}

provider "aws" {
  region = var.aws_region

  # default_tags aplica estas etiquetas a TODOS los recursos que soporten tags.
  # Es la base del control de costos (FinOps): permite filtrar el gasto por
  # proyecto, ambiente y dueño en Cost Explorer y Budgets.
  default_tags {
    tags = {
      Project     = var.project_name
      Environment = var.environment
      Owner       = var.owner
      ManagedBy   = "terraform"
    }
  }
}
