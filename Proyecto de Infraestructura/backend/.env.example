# Servidor
PORT=3000

# AWS / DynamoDB
AWS_REGION=us-east-1
DYNAMODB_TABLE=patentes
# Para desarrollo local con DynamoDB Local (Docker). En producción dejar vacío.
# Usar 127.0.0.1 (no "localhost") para evitar cuelgues por IPv6 en Windows.
DYNAMODB_ENDPOINT=http://127.0.0.1:8000

# API de Boostr (patentes Chile) — https://api.boostr.cl/patente
BOOSTR_BASE_URL=https://api.boostr.cl
BOOSTR_API_KEY=tu_api_key_de_boostr_aqui
# include=owner agrega nombre y RUT del dueño (según tu plan)
BOOSTR_INCLUDE=owner
